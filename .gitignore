# =============================================================================
# .gitignore — Travel Concierge (Python / ADK)
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
*.pem
*.key
service-account*.json

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# uv
# ---------------------------------------------------------------------------
# Lock file is intentionally NOT ignored — commit it for reproducible builds.
# uv.lock

# ---------------------------------------------------------------------------
# ADK / agents-cli
# ---------------------------------------------------------------------------
.agents-cli/
agents-cli-manifest.yaml

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.log
tmp/
.deploy_staging/
app/.adk/
